
# SecureCommerce AI Configuration

# Project
PROJECT_NAME=SecureCommerceAI
ENVIRONMENT=development

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=login_events

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=securecommerce123

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=securecommerce_ai

# Streamlit
STREAMLIT_PORT=8501

# Producer
LOGIN_EVENTS_PER_SECOND=5

# Machine Learning
MODEL_PATH=/app/models/model.pkl
SCALER_PATH=/app/models/scaler.pkl

# Logging
LOG_LEVEL=INFO

# Timezone
TZ=Asia/Kolkata